---
/**
 * Mono-caps artifact link pointing at a document, PDF, or external artifact.
 * Rendered as a plain underlined link, not a bordered chip, matching the
 * Architect's Studio identity (hairlines + typography carry the structure;
 * no decorative containers for inline affordances).
 *
 * Icon is an optional Material Symbols Outlined name (e.g. "description",
 * "receipt_long") rendered at the label's baseline for redundancy.
 */

interface Props {
  icon?: string
  label: string
  href: string
}

const { icon, label, href } = Astro.props
---

<a
  href={href}
  class="inline-flex items-center gap-1.5 font-mono text-label uppercase tracking-[var(--ss-text-letter-spacing-label)] font-semibold text-[color:var(--ss-color-text-secondary)] hover:text-[color:var(--ss-color-text-primary)] underline decoration-[color:var(--ss-color-border)] hover:decoration-[color:var(--ss-color-text-primary)] underline-offset-4 decoration-1 transition-colors"
>
  {icon && <span class="material-symbols-outlined text-[14px]">{icon}</span>}
  <span>{label}</span>
</a>
