---
// How We Engage — replaces HowItWorks + Pricing flow grid. One narrative
// of how an engagement runs, plus the price-shape rationale as a sub-block.
//
// Doctrine: no fixed timeframes, no published dollar amounts, "we" voice,
// no fabricated outcomes, no personalized outreach-promise templates.
const beats = [
  {
    title: 'We listen first',
    body: 'We start with a conversation. What are you trying to accomplish? Where do things get stuck? We listen until we understand the business, the people, and what success looks like, before we propose anything.',
  },
  {
    title: 'We figure it out together',
    body: 'You know your business. We bring operational experience. The shape of the solution comes from both, not a kit we showed up with.',
  },
  {
    title: 'You see the scope and price before you commit',
    body: "Once we've defined a solution, we put together a written scope and a fixed project price. You see both before you commit. We adjust the shape until it fits, and we'll tell you if we're not the right people for the work.",
  },
  {
    title: 'We build and train alongside your team',
    body: 'We design, build, configure, and train alongside your team. The engagement ends when your team is running what we built, with documentation in their hands. We stay available if a follow-up makes sense.',
  },
]

const priceShape = [
  'Fixed price. You see the total before work starts.',
  'Scoped to your objectives, not a vague retainer.',
  'No commitment until after the conversation.',
  'Smallest engagements start small. Pricing fits the shape of the problem.',
]
---

<section
  class="bg-[color:var(--ss-color-background)] px-6 py-24 border-t-[3px] border-[color:var(--ss-color-text-primary)]"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-16">
      <span
        class="inline-block bg-[color:var(--ss-color-text-primary)] text-[color:var(--ss-color-background)] font-['JetBrains_Mono'] text-xs font-semibold uppercase tracking-[0.14em] px-2 py-1 mb-4"
        >§ 03</span
      >
      <h2
        class="font-['Archivo'] text-4xl md:text-5xl font-black uppercase tracking-[-0.02em] text-[color:var(--ss-color-text-primary)]"
      >
        How We Engage
      </h2>
      <p
        class="mt-6 max-w-2xl font-['Archivo'] text-lg text-balance text-[color:var(--ss-color-text-secondary)]"
      >
        From first conversation to full handoff. Same shape every time, scoped to your business.
      </p>
    </div>

    <div class="space-y-0 border-t-[3px] border-[color:var(--ss-color-text-primary)]">
      {
        beats.map((step, i) => (
          <div class="flex gap-8 py-10 border-b-[3px] border-[color:var(--ss-color-text-primary)]">
            <div class="font-['Archivo'] text-6xl font-black leading-none text-[color:var(--ss-color-primary)] tracking-[-0.03em] min-w-[5rem]">
              {String(i + 1).padStart(2, '0')}
            </div>
            <div class="flex-1">
              <h3 class="mb-3 font-['Archivo'] text-2xl font-bold uppercase tracking-[-0.01em] text-[color:var(--ss-color-text-primary)]">
                {step.title}
              </h3>
              <p class="font-['Archivo'] leading-relaxed text-[color:var(--ss-color-text-secondary)]">
                {step.body}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 grid grid-cols-1 gap-0 md:grid-cols-12">
      <div
        class="md:col-span-5 py-10 md:py-12 md:pr-10 border-b-[3px] md:border-b-0 md:border-r-[3px] border-[color:var(--ss-color-text-primary)]"
      >
        <p
          class="font-['Archivo_Narrow'] text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--ss-color-primary)]"
        >
          How we price
        </p>
        <h3
          class="mt-3 font-['Archivo'] text-3xl md:text-4xl font-black uppercase tracking-[-0.02em] text-[color:var(--ss-color-text-primary)]"
        >
          Scoped to your business
        </h3>
        <p
          class="mt-6 font-['Archivo'] leading-relaxed text-[color:var(--ss-color-text-secondary)]"
        >
          Every business is different. We quote a fixed price after we understand yours. No hourly
          billing, no open-ended retainers, no surprises.
        </p>
      </div>
      <div class="md:col-span-7 py-10 md:py-12 md:pl-10">
        <ul class="space-y-5">
          {
            priceShape.map((item) => (
              <li class="flex items-start gap-4">
                <span class="mt-2 inline-block w-3 h-3 shrink-0 bg-[color:var(--ss-color-primary)]" />
                <span class="font-['Archivo'] leading-snug text-[color:var(--ss-color-text-primary)]">
                  {item}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
