---
const problems = [
  { name: 'Everything runs through you', quote: "I can't take a day off" },
  { name: 'Leads slip away', quote: 'Leads fall through the cracks' },
  { name: 'No visibility into the numbers', quote: "I have no idea if we're making money" },
  { name: 'Scheduling is a mess', quote: 'Double-bookings happen all the time' },
  { name: 'Every message is manual', quote: 'I personally text every customer' },
  { name: 'Good people leave', quote: 'I keep losing good people' },
]
---

<section class="bg-slate-50 px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold text-slate-900">Sound Familiar?</h2>
    </div>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        problems.map((problem) => (
          <div class="flex flex-col justify-between rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
            <p class="italic leading-relaxed text-slate-700">"{problem.quote}"</p>
            <p class="mt-6 text-sm font-medium text-slate-500">{problem.name}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
