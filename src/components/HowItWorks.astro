---
const steps = [
  {
    day: 'Day 1',
    title: 'Audit Call',
    description:
      'We walk through your day, watch how things actually work, and identify the top 3 problems holding your business back.',
  },
  {
    day: 'Days 2\u20135',
    title: 'Design & Build',
    description:
      'We choose the simplest tools that solve your problems, build the workflows, and configure everything end-to-end.',
  },
  {
    day: 'Days 6\u20137',
    title: 'Training & Handoff',
    description:
      'Your team gets hands-on training, written how-to docs, and an internal champion who knows the new systems inside out.',
  },
  {
    day: 'Days 8\u201310',
    title: 'Buffer & Polish',
    description:
      'We handle feedback, adjust based on real usage, and make sure everything works before we walk away.',
  },
]
---

<section class="bg-white px-4 py-16 sm:py-24">
  <div class="mx-auto max-w-screen-lg">
    <h2 class="text-center text-3xl font-bold text-gray-900">How It Works</h2>
    <div class="mt-12 space-y-8 border-l-2 border-brand pl-8">
      {
        steps.map((step) => (
          <div class="relative">
            <div class="absolute -left-[calc(2rem+5px)] top-1 h-2.5 w-2.5 rounded-full bg-brand" />
            <span class="inline-flex items-center rounded-full bg-brand px-3 py-1 text-sm font-semibold text-white">
              {step.day}
            </span>
            <h3 class="mt-2 text-xl font-bold text-gray-900">{step.title}</h3>
            <p class="mt-1 text-gray-600">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
