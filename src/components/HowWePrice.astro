---
// How We Price — extracted from §03 HowWeEngage's sub-block. Promoted to
// its own section per the IA review: pricing transparency is a load-bearing
// trust signal for the audience SMD targets; H2 dignity reads as confidence,
// not nervousness.
//
// Surface: full-bleed inverse (`--ss-color-surface-inverse`). Reuses
// FinalCta's full-bleed architectural pattern. Together with FinalCta, the
// page now carries two dark rhythm breaks at ~40% and 100% scroll.
//
// Doctrine: no fabricated dollars, no fixed timeframes, no negative framing,
// no AI rhetoric, "we" voice, single-accent burnt orange holds, no CTA in
// this section (statement, not conversion).
const priceShape = [
  'One price for the engagement. You see the total before you commit.',
  'Engagements scale to the work. A small problem gets a small project.',
]
---

<section
  class="bg-[color:var(--ss-color-surface-inverse)] px-6 py-24 border-t-[3px] border-[color:var(--ss-color-text-primary)]"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-16">
      <span
        class="inline-block bg-[color:var(--ss-color-background)] text-[color:var(--ss-color-text-primary)] font-['JetBrains_Mono'] text-xs font-semibold uppercase tracking-[0.14em] px-2 py-1 mb-4"
        >§ 04</span
      >
      <p
        class="font-['Archivo_Narrow'] text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--ss-color-primary)] mb-3"
      >
        How we price
      </p>
      <h2
        class="font-['Archivo'] text-4xl md:text-5xl font-black uppercase tracking-[-0.02em] text-[color:var(--ss-color-background)]"
      >
        We Quote A Fixed Price
      </h2>
      <p
        class="mt-6 max-w-2xl font-['Archivo'] text-lg text-balance text-[color:var(--ss-color-background)]/80"
      >
        Every business is different. We learn how yours runs, then quote a fixed price for the work.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-0 md:grid-cols-12">
      <div class="md:col-span-5 py-6 md:py-0 md:pr-10"></div>
      <div
        class="md:col-span-7 py-6 md:py-0 md:pl-10 md:border-l md:border-[color:var(--ss-color-background)]/15"
      >
        <ul class="space-y-5">
          {
            priceShape.map((item) => (
              <li class="flex items-start gap-4">
                <span class="mt-2 inline-block w-3 h-3 shrink-0 bg-[color:var(--ss-color-primary)]" />
                <span class="font-['Archivo'] leading-snug text-[color:var(--ss-color-background)]">
                  {item}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
