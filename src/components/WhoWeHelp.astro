---
const segments = [
  {
    title: 'Outgrowing Your Tools',
    pain: 'You started with spreadsheets and free apps. They worked fine at first. Now everything takes longer than it should, data lives in five places, and you spend half your week just keeping things from falling apart.',
    fix: 'The right tools for where you are now, set up to work together. No more re-entering the same data in three places.',
  },
  {
    title: 'Stuck in Every Decision',
    pain: "Nothing moves without you. Your team checks with you on things they should be able to handle. You know you need to delegate, but there's no process to delegate to.",
    fix: 'Documented workflows your team can follow on their own. Clear enough that people stop asking and start doing.',
  },
  {
    title: 'Ready to Grow but Afraid Things Will Break',
    pain: "You could take on more work. You could hire. But you know the way things run right now won't hold. Growth feels risky when you can't see what's happening across the business.",
    fix: 'Visibility into what matters and processes that hold up under pressure. So growth is exciting, not terrifying.',
  },
]
---

<section class="bg-[color:var(--color-background)] px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-12 text-center text-3xl font-bold text-[color:var(--color-text-primary)]">
      Who We Help
    </h2>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        segments.map((s) => (
          <div class="rounded-[var(--radius-card)] border border-[color:var(--color-border)] bg-white p-8">
            <h3 class="text-xl font-bold text-[color:var(--color-text-primary)]">{s.title}</h3>
            <div class="mt-6">
              <p class="text-xs font-semibold uppercase tracking-wider text-[color:var(--color-text-secondary)]">
                Sound familiar?
              </p>
              <p class="mt-2 text-[color:var(--color-text-primary)]">{s.pain}</p>
            </div>
            <div class="mt-4">
              <p class="text-xs font-semibold uppercase tracking-wider text-primary">How we help</p>
              <p class="mt-2 text-[color:var(--color-text-primary)]">{s.fix}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
