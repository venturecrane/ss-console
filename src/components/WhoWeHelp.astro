---
const segments = [
  {
    title: 'Outgrowing Your Tools',
    pain: 'You started with spreadsheets and free apps. They worked fine at first. Now everything takes longer than it should, data lives in five places, and you spend half your week just keeping things from falling apart.',
    fix: 'The right tools for where you are now, set up to work together. No more re-entering the same data in three places.',
  },
  {
    title: 'Stuck in Every Decision',
    pain: "Nothing moves without you. Your team checks with you on things they should be able to handle. You know you need to delegate, but there's no process to delegate to.",
    fix: 'Documented workflows your team can follow on their own. Clear enough that people stop asking and start doing.',
  },
  {
    title: 'Ready to Grow but Afraid Things Will Break',
    pain: "You could take on more work. You could hire. But you know the way things run right now won't hold. Growth feels risky when you can't see what's happening across the business.",
    fix: 'Visibility into what matters and processes that hold up under pressure. So growth is exciting, not terrifying.',
  },
]
---

<section
  class="bg-[color:var(--color-background)] px-6 py-24 border-t-[3px] border-[color:var(--color-text-primary)]"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-16">
      <span
        class="inline-block bg-[color:var(--color-text-primary)] text-[color:var(--color-background)] font-['JetBrains_Mono'] text-xs font-semibold uppercase tracking-[0.14em] px-2 py-1 mb-4"
        >§ 05</span
      >
      <h2
        class="font-['Archivo'] text-4xl md:text-5xl font-black uppercase tracking-[-0.02em] text-[color:var(--color-text-primary)]"
      >
        Who We Help
      </h2>
    </div>
    <div
      class="grid grid-cols-1 gap-0 md:grid-cols-3 border-t-[3px] border-[color:var(--color-text-primary)]"
    >
      {
        segments.map((s, i) => (
          <div
            class:list={[
              'p-8 bg-[color:var(--color-background)] border-b-[3px] border-[color:var(--color-text-primary)]',
              i !== 2 && 'md:border-r-[3px] md:border-[color:var(--color-text-primary)]',
            ]}
          >
            <h3 class="font-['Archivo'] text-xl font-bold uppercase tracking-[-0.01em] text-[color:var(--color-text-primary)]">
              {s.title}
            </h3>
            <div class="mt-6">
              <p class="font-['Archivo_Narrow'] text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--color-text-secondary)]">
                Sound familiar?
              </p>
              <p class="mt-2 font-['Archivo'] text-[color:var(--color-text-primary)]">{s.pain}</p>
            </div>
            <div class="mt-6 pt-6 border-t border-[color:var(--color-border)]">
              <p class="font-['Archivo_Narrow'] text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--color-primary)]">
                How we help
              </p>
              <p class="mt-2 font-['Archivo'] text-[color:var(--color-text-primary)]">{s.fix}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
