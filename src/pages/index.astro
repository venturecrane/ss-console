---
// SSR required: middleware needs to intercept portal.smd.services requests to this path
// and rewrite them to /portal. The prerendered static file would bypass the Worker entirely.
export const prerender = false

import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import ProblemCards from '../components/ProblemCards.astro'
import RoiMath from '../components/RoiMath.astro'
import HowWeEngage from '../components/HowWeEngage.astro'
import HowWePrice from '../components/HowWePrice.astro'
import WhatYouGet from '../components/WhatYouGet.astro'
import CaseStudies from '../components/CaseStudies.astro'
import About from '../components/About.astro'
import WhatWeWontDo from '../components/WhatWeWontDo.astro'
import FinalCta from '../components/FinalCta.astro'
import Footer from '../components/Footer.astro'
---

<Base title="SMD Services | Solutions Consulting for Growing Businesses">
  <Nav />
  <main id="main" role="main">
    <Hero />
    <ProblemCards />
    <RoiMath />
    <HowWeEngage />
    <HowWePrice />
    <WhatYouGet />
    <CaseStudies />
    <About />
    <WhatWeWontDo />
    <FinalCta />
  </main>
  <Footer />
</Base>
