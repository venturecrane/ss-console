---
import Base from '../../../layouts/Base.astro'
---

<Base title="SMD Services — Modern Institutional (preview)">
  <header class="site-header">
    <a href="/design-preview/modern-institutional/" class="brand" aria-label="SMD Services">
      <span class="wordmark"><span>SMD</span> <em>Services</em></span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <ul>
        <li><a href="/design-preview/modern-institutional/" class="active">Home</a></li>
        <li><a href="/design-preview/modern-institutional/contact">Contact</a></li>
        <li><a href="/design-preview/modern-institutional/contact" class="cta">Book a call</a></li>
      </ul>
    </nav>
  </header>

  <main id="main">
    <section class="hero">
      <div class="eyebrow">Fractional operations — Phoenix, Arizona</div>
      <h1>Your business has outgrown how you <em>run it.</em></h1>
      <p class="hero-lede">
        SMD Services works alongside owners to install the systems, rhythms, and reporting that turn
        a busy practice into a business that runs without you in the room.
      </p>
      <div class="cta-row">
        <a href="/design-preview/modern-institutional/contact" class="btn primary">Book a call</a>
        <a href="/design-preview/modern-institutional/contact" class="btn outline">
          Tell us about your business
        </a>
      </div>
    </section>

    <section class="section">
      <div class="section-title">
        <div class="eyebrow">What owners tell us</div>
        <h2>The sentences we hear most often.</h2>
      </div>
      <div class="problem-grid">
        <div class="problem">
          <p class="quote">
            "I can't step away from the business without everything falling apart."
          </p>
          <div class="tag">Owner bottleneck</div>
        </div>
        <div class="problem">
          <p class="quote">
            "My books are up to date, but I still can't tell you if last month was good."
          </p>
          <div class="tag">Reporting gap</div>
        </div>
        <div class="problem">
          <p class="quote">
            "Every week there's a new fire. We never get to the work that actually grows us."
          </p>
          <div class="tag">Operating drag</div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-title">
        <div class="eyebrow">How we work together</div>
        <h2>Four steps. No boilerplate.</h2>
      </div>
      <div class="process">
        <div class="step">
          <div class="num">§ 01</div>
          <h3>Learn your business</h3>
          <p>
            We start with a conversation. What are you trying to accomplish? Where do things get
            stuck? We listen until we understand the business, not just the org chart.
          </p>
        </div>
        <div class="step">
          <div class="num">§ 02</div>
          <h3>Map the operating picture</h3>
          <p>
            We walk through your numbers, your calendar, and your weekly rhythms. You get a written
            summary of what's working and what's in the way.
          </p>
        </div>
        <div class="step">
          <div class="num">§ 03</div>
          <h3>Install the systems</h3>
          <p>
            We build or fix the parts that matter first: cash reporting, owner dashboards, team
            cadence, SOPs. Small, durable changes, nothing you can't maintain.
          </p>
        </div>
        <div class="step">
          <div class="num">§ 04</div>
          <h3>Hand it back</h3>
          <p>
            Engagements end. We leave behind a business you can run with or without us, and a
            standing invitation to call when the next thing breaks.
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-title">
        <div class="eyebrow">Engagement types</div>
        <h2>Three ways we work.</h2>
      </div>
      <div class="pricing">
        <div class="tier">
          <div class="tier-lbl">Assessment</div>
          <h3>Operating Picture</h3>
          <p class="sub">A two-week diagnostic. Written findings, prioritized.</p>
          <div class="price">$6,500</div>
          <ul>
            <li>Two-week engagement</li>
            <li>Financial and operational review</li>
            <li>Written report with priorities</li>
            <li>Recommendation conversation</li>
          </ul>
        </div>
        <div class="tier featured">
          <div class="tier-lbl">Fractional</div>
          <h3>Fractional Operator</h3>
          <p class="sub">Ongoing weekly engagement. The work of running the business with you.</p>
          <div class="price">$9,500<span>/mo</span></div>
          <ul>
            <li>Weekly operating rhythm</li>
            <li>Owner dashboard and cash reporting</li>
            <li>SOPs, hiring, vendor management</li>
            <li>Three-month minimum</li>
          </ul>
        </div>
        <div class="tier">
          <div class="tier-lbl">Project</div>
          <h3>Targeted Project</h3>
          <p class="sub">A scoped problem with a clear finish line.</p>
          <div class="price">From $12k</div>
          <ul>
            <li>Fixed scope, fixed price</li>
            <li>ERP and systems migrations</li>
            <li>Exit and acquisition prep</li>
            <li>Four to twelve weeks</li>
          </ul>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div>
      <a
        href="/design-preview/modern-institutional/"
        class="brand brand-footer"
        aria-label="SMD Services"
      >
        <span class="wordmark"><span>SMD</span> <em>Services</em></span>
      </a>
      <div class="copyright">© 2026 SMDurgan, LLC · Phoenix, Arizona</div>
    </div>
    <nav class="site-nav" aria-label="Footer">
      <ul>
        <li><a href="/design-preview/modern-institutional/contact">Contact</a></li>
        <li><a href="/design-preview/modern-institutional/legal">Privacy</a></li>
        <li><a href="/design-preview/modern-institutional/legal">Terms</a></li>
      </ul>
    </nav>
  </footer>
</Base>

<style>
  main {
    max-width: 1180px;
    margin: 0 auto;
    background: var(--color-background);
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 40px;
    max-width: 1180px;
    margin: 0 auto;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .brand .wordmark {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
  }
  .brand .wordmark em {
    color: var(--color-primary);
    font-style: italic;
    font-weight: 500;
  }
  .brand-footer .wordmark {
    font-size: 18px;
  }
  .site-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 24px;
    align-items: center;
  }
  .site-nav a {
    font-size: 14px;
    color: var(--color-text-secondary);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--motion-default);
  }
  .site-nav a:hover,
  .site-nav a.active {
    color: var(--color-text-primary);
  }
  .site-nav a.cta {
    background: var(--color-primary);
    color: white;
    padding: 8px 20px;
  }
  .site-nav a.cta:hover {
    background: var(--color-primary-hover);
    color: white;
  }

  .hero {
    padding: 88px 40px 72px;
    max-width: 920px;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-meta);
    margin-bottom: 20px;
  }
  .hero h1 {
    max-width: 740px;
    margin-bottom: 28px;
  }
  .hero h1 em {
    color: var(--color-primary);
    font-weight: 500;
    font-style: italic;
  }
  .hero-lede {
    font-size: 19px;
    line-height: 30px;
    color: var(--color-text-secondary);
    max-width: 680px;
    margin-bottom: 36px;
  }
  .cta-row {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    font-family: inherit;
    font-size: 16px;
    font-weight: 600;
    padding: 13px 28px;
    border: 0;
    cursor: pointer;
    transition:
      background var(--motion-default),
      color var(--motion-default);
    text-decoration: none;
  }
  .btn.primary {
    background: var(--color-primary);
    color: white;
  }
  .btn.primary:hover {
    background: var(--color-primary-hover);
  }
  .btn.outline {
    background: transparent;
    color: var(--color-text-primary);
    border: 2px solid var(--color-text-primary);
    padding: 11px 26px;
  }
  .btn.outline:hover {
    background: var(--color-text-primary);
    color: var(--color-background);
  }

  .section {
    padding: 64px 40px;
    border-top: 1px solid var(--color-border-subtle);
  }
  .section-title {
    margin-bottom: 40px;
  }
  .section-title h2 {
    max-width: 720px;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .problem {
    padding: 28px;
    border-right: 1px solid var(--color-border-subtle);
  }
  .problem:last-child {
    border-right: 0;
  }
  .problem p.quote {
    font-style: italic;
    font-size: 17px;
    line-height: 1.55;
    color: var(--color-text-primary);
  }
  .problem .tag {
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-meta);
    text-transform: uppercase;
  }

  .process {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .step {
    padding: 32px;
    border-right: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .step:nth-child(2n) {
    border-right: 0;
  }
  .step:nth-last-child(-n + 2) {
    border-bottom: 0;
  }
  .step .num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-meta);
    margin-bottom: 10px;
    text-transform: uppercase;
  }
  .step h3 {
    margin-bottom: 10px;
  }
  .step p {
    color: var(--color-text-secondary);
    font-size: 15px;
    line-height: 1.55;
  }

  .pricing {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .tier {
    padding: 32px;
    border-right: 1px solid var(--color-border-subtle);
  }
  .tier:last-child {
    border-right: 0;
  }
  .tier.featured {
    background: var(--color-surface-inverse);
    color: #f9f7f1;
  }
  .tier.featured h3,
  .tier.featured .price {
    color: #f9f7f1;
  }
  .tier.featured p,
  .tier.featured li {
    color: rgba(249, 247, 241, 0.7);
  }
  .tier.featured .tier-lbl {
    color: #dbb05c;
  }
  .tier-lbl {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-meta);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .tier h3 {
    margin-bottom: 6px;
  }
  .tier p.sub {
    font-size: 14px;
    color: var(--color-text-secondary);
    min-height: 38px;
    margin-bottom: 22px;
  }
  .tier .price {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin-bottom: 24px;
  }
  .tier .price span {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-left: 4px;
    font-weight: 400;
  }
  .tier ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border-subtle);
  }
  .tier.featured ul {
    border-top-color: rgba(249, 247, 241, 0.12);
  }
  .tier li {
    padding: 11px 0;
    border-bottom: 1px solid var(--color-border-subtle);
    font-size: 14px;
    color: var(--color-text-secondary);
  }
  .tier.featured li {
    border-bottom-color: rgba(249, 247, 241, 0.12);
  }
  .tier li:last-child {
    border-bottom: 0;
  }

  .site-footer {
    padding: 32px 40px;
    max-width: 1180px;
    margin: 0 auto;
    border-top: 1px solid var(--color-border);
    background: var(--color-background);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 14px;
    color: var(--color-text-secondary);
  }
  .site-footer .copyright {
    margin-top: 8px;
    font-size: 13px;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .site-header,
    .hero,
    .section,
    .site-footer {
      padding-left: 24px;
      padding-right: 24px;
    }
    .hero {
      padding-top: 56px;
      padding-bottom: 48px;
    }
    .problem-grid,
    .process,
    .pricing {
      grid-template-columns: 1fr;
    }
    .problem,
    .step,
    .tier {
      border-right: 0 !important;
      border-bottom: 1px solid var(--color-border-subtle);
    }
    .step:nth-last-child(-n + 2) {
      border-bottom: 1px solid var(--color-border-subtle);
    }
    .problem:last-child,
    .step:last-child,
    .tier:last-child {
      border-bottom: 0;
    }
  }
</style>
