---
import Base from '../../../layouts/Base.astro'
---

<Base title="SMD Services — Desert Functional (preview)">
  <div class="df">
    <header class="df-header">
      <a href="/design-preview/desert-functional/" class="df-brand" aria-label="SMD Services">
        <span>SMD Services</span>
        <span class="df-brand-mark" aria-hidden="true"></span>
      </a>
      <nav aria-label="Primary">
        <ul class="df-nav">
          <li><a href="/design-preview/desert-functional/" class="df-nav-link">Work</a></li>
          <li>
            <a href="/design-preview/desert-functional/contact" class="df-nav-link">Contact</a>
          </li>
          <li>
            <a href="/design-preview/desert-functional/contact" class="df-nav-cta">Book a call</a>
          </li>
        </ul>
      </nav>
    </header>

    <main id="main">
      <section class="df-hero">
        <div class="df-eyebrow">Fractional operations, Phoenix</div>
        <h1 class="df-display">
          Your business has outgrown<br />
          how you <em>run it.</em>
        </h1>
        <p class="df-lede">
          SMD Services works alongside owners to install the systems, rhythms, and reporting that
          turn a busy practice into a business that runs without you in the room. Single operator,
          not an agency. Claude Partner Network Services applicant.
        </p>
        <div class="df-cta-row">
          <a href="/design-preview/desert-functional/contact" class="df-btn-primary">Book a call</a>
          <a href="/design-preview/desert-functional/contact" class="df-btn-arrow">
            Tell us about your business <span aria-hidden="true">→</span>
          </a>
        </div>
      </section>

      <section class="df-section">
        <div class="df-section-head">
          <div class="df-roman">i.</div>
          <h2 class="df-title">What owners tell us.</h2>
        </div>
        <div class="df-quote-grid">
          <div class="df-quote">
            <div class="df-quote-num">01.</div>
            <p class="df-quote-body">
              "I can't step away from the business without everything falling apart."
            </p>
            <div class="df-rule-short" aria-hidden="true"></div>
            <div class="df-tag">Owner bottleneck</div>
          </div>
          <div class="df-quote">
            <div class="df-quote-num">02.</div>
            <p class="df-quote-body">
              "My books are up to date, but I still can't tell you if last month was good."
            </p>
            <div class="df-rule-short" aria-hidden="true"></div>
            <div class="df-tag">Reporting gap</div>
          </div>
          <div class="df-quote">
            <div class="df-quote-num">03.</div>
            <p class="df-quote-body">
              "Every week there's a new fire. We never get to the work that actually grows us."
            </p>
            <div class="df-rule-short" aria-hidden="true"></div>
            <div class="df-tag">Operating drag</div>
          </div>
        </div>
      </section>

      <section class="df-section df-section-pricing">
        <div class="df-section-head">
          <div class="df-roman">ii.</div>
          <h2 class="df-title">Three ways we work.</h2>
        </div>
        <div class="df-pricing-grid">
          <article class="df-tier">
            <div class="df-tier-lbl">Assessment</div>
            <h3 class="df-tier-name">Operating Picture</h3>
            <p class="df-tier-sub">A two-week diagnostic. Written findings, prioritized.</p>
            <div class="df-tier-price">$6,500</div>
            <div class="df-tier-price-note">fixed</div>
            <div class="df-tier-rule" aria-hidden="true"></div>
            <ul class="df-tier-list">
              <li>Two-week engagement</li>
              <li>Financial and operational review</li>
              <li>Written report with priorities</li>
              <li>Recommendation conversation</li>
            </ul>
            <a href="/design-preview/desert-functional/contact" class="df-tier-cta">
              Book a call <span aria-hidden="true">→</span>
            </a>
          </article>
          <article class="df-tier df-tier-featured">
            <div class="df-tier-lbl">Fractional</div>
            <h3 class="df-tier-name">Fractional Operator</h3>
            <p class="df-tier-sub">
              Ongoing weekly engagement. The work of running the business with you.
            </p>
            <div class="df-tier-price">$9,500</div>
            <div class="df-tier-price-note">per month</div>
            <div class="df-tier-rule" aria-hidden="true"></div>
            <ul class="df-tier-list">
              <li>Weekly operating rhythm</li>
              <li>Owner dashboard and cash reporting</li>
              <li>SOPs, hiring, vendor management</li>
              <li>Three-month minimum</li>
            </ul>
            <a href="/design-preview/desert-functional/contact" class="df-tier-cta">
              Book a call <span aria-hidden="true">→</span>
            </a>
          </article>
          <article class="df-tier">
            <div class="df-tier-lbl">Project</div>
            <h3 class="df-tier-name">Targeted Project</h3>
            <p class="df-tier-sub">A scoped problem with a clear finish line.</p>
            <div class="df-tier-price">From $12,000</div>
            <div class="df-tier-price-note">fixed</div>
            <div class="df-tier-rule" aria-hidden="true"></div>
            <ul class="df-tier-list">
              <li>Fixed scope, fixed price</li>
              <li>ERP and systems migrations</li>
              <li>Exit and acquisition prep</li>
              <li>Four to twelve weeks</li>
            </ul>
            <a href="/design-preview/desert-functional/contact" class="df-tier-cta">
              Book a call <span aria-hidden="true">→</span>
            </a>
          </article>
        </div>
      </section>

      <footer class="df-footer">
        <div>
          <div class="df-brand df-brand-footer">
            <span>SMD Services</span>
            <span class="df-brand-mark" aria-hidden="true"></span>
          </div>
          <div class="df-foot-note">SMDurgan, LLC · Phoenix, Arizona · © 2026</div>
        </div>
        <nav aria-label="Footer">
          <ul class="df-nav df-nav-foot">
            <li>
              <a href="/design-preview/desert-functional/contact" class="df-nav-link">Contact</a>
            </li>
            <li>
              <a href="/design-preview/desert-functional/legal" class="df-nav-link">Privacy</a>
            </li>
            <li>
              <a href="/design-preview/desert-functional/legal" class="df-nav-link">Terms</a>
            </li>
          </ul>
        </nav>
      </footer>
    </main>
  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap');

  /* --- Desert Functional tokens (scoped to preview) --- */
  .df {
    --df-bg: #ede6d6;
    --df-surface: #f6f1e4;
    --df-surface-inverse: #22201c;
    --df-text-primary: #22201c;
    --df-text-secondary: #5c564d;
    --df-text-muted: #928a7c;
    --df-accent: #b8852a;
    --df-accent-soft-on-dark: #b8852a;
    --df-status-sage: #6a7a68;
    --df-hairline: rgba(34, 32, 28, 0.14);
    --df-hairline-on-dark: rgba(237, 230, 214, 0.16);
    --df-inverse-text-primary: #ede6d6;
    --df-inverse-text-secondary: rgba(237, 230, 214, 0.72);
    --df-inverse-text-muted: rgba(237, 230, 214, 0.6);

    background: var(--df-bg);
    color: var(--df-text-primary);
    font-family: Inter, system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    letter-spacing: -0.005em;
    font-feature-settings: 'ss01', 'cv11';
  }

  /* --- chrome --- */
  .df-header {
    padding: 28px 72px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .df-brand {
    font-family: Inter, sans-serif;
    font-weight: 600;
    font-size: 17px;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--df-text-primary);
    text-decoration: none;
  }
  .df-brand-mark {
    width: 6px;
    height: 6px;
    background: var(--df-accent);
    display: inline-block;
  }
  .df-brand-footer {
    font-size: 15px;
    margin-bottom: 6px;
  }

  .df-nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 32px;
    align-items: center;
  }
  .df-nav-link {
    font-size: 14px;
    color: var(--df-text-secondary);
    font-weight: 500;
    letter-spacing: -0.005em;
    text-decoration: none;
  }
  .df-nav-link:hover {
    color: var(--df-text-primary);
  }
  .df-nav-cta {
    color: var(--df-text-primary);
    font-size: 14px;
    font-weight: 600;
    border-bottom: 1.5px solid var(--df-accent);
    padding-bottom: 2px;
    text-decoration: none;
  }

  /* --- hero --- */
  .df-hero {
    padding: 160px 72px 144px;
    max-width: 1152px;
  }
  .df-eyebrow {
    font-family: Inter, sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--df-text-muted);
    font-weight: 500;
    margin-bottom: 48px;
  }
  .df-display {
    font-family: Inter, sans-serif;
    font-size: 76px;
    line-height: 1.02;
    font-weight: 500;
    letter-spacing: -0.03em;
    margin: 0 0 40px;
    max-width: 980px;
    color: var(--df-text-primary);
  }
  .df-display em {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--df-accent);
    letter-spacing: -0.01em;
  }
  .df-lede {
    font-size: 21px;
    line-height: 1.5;
    color: var(--df-text-secondary);
    max-width: 680px;
    margin: 0 0 56px;
    letter-spacing: -0.005em;
    font-weight: 400;
  }
  .df-cta-row {
    display: flex;
    gap: 36px;
    align-items: center;
    flex-wrap: wrap;
  }
  .df-btn-primary {
    background: var(--df-surface-inverse);
    color: var(--df-inverse-text-primary);
    padding: 16px 32px;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.005em;
    border: 0;
    text-decoration: none;
    display: inline-block;
  }
  .df-btn-primary:hover {
    background: #000;
  }
  .df-btn-arrow {
    background: transparent;
    color: var(--df-text-primary);
    font-size: 15px;
    font-weight: 500;
    padding: 16px 0;
    letter-spacing: -0.005em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .df-btn-arrow span {
    color: var(--df-accent);
    font-size: 16px;
  }

  /* --- sections --- */
  .df-section {
    padding: 104px 72px;
  }
  .df-section-pricing {
    padding-bottom: 144px;
  }
  .df-section-head {
    margin-bottom: 72px;
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 24px;
    align-items: baseline;
  }
  .df-roman {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: 28px;
    color: var(--df-accent);
    font-weight: 400;
  }
  .df-title {
    font-family: Inter, sans-serif;
    font-size: 40px;
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.025em;
    margin: 0;
    max-width: 740px;
    color: var(--df-text-primary);
  }

  /* --- problem grid --- */
  .df-quote-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 56px;
    padding-left: 144px;
  }
  .df-quote-num {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: 20px;
    color: var(--df-accent);
    margin-bottom: 24px;
  }
  .df-quote-body {
    font-size: 20px;
    line-height: 1.45;
    color: var(--df-text-primary);
    margin: 0 0 24px;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .df-rule-short {
    height: 1px;
    background: var(--df-hairline);
    width: 32px;
    margin: 20px 0;
  }
  .df-tag {
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--df-status-sage);
    font-weight: 600;
  }

  /* --- pricing --- */
  .df-pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    padding-left: 144px;
  }
  .df-tier {
    background: var(--df-surface);
    padding: 40px 36px 36px;
    display: flex;
    flex-direction: column;
    min-height: 440px;
    color: var(--df-text-primary);
  }
  .df-tier-featured {
    background: var(--df-surface-inverse);
    color: var(--df-inverse-text-primary);
  }
  .df-tier-lbl {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--df-text-muted);
    font-weight: 500;
    margin-bottom: 20px;
  }
  .df-tier-featured .df-tier-lbl {
    color: var(--df-accent);
  }
  .df-tier-name {
    font-family: Inter, sans-serif;
    font-size: 26px;
    font-weight: 500;
    margin: 0 0 12px;
    letter-spacing: -0.02em;
    color: inherit;
  }
  .df-tier-sub {
    font-size: 15px;
    color: var(--df-text-secondary);
    line-height: 1.5;
    margin: 0 0 32px;
    min-height: 66px;
    letter-spacing: -0.005em;
  }
  .df-tier-featured .df-tier-sub {
    color: var(--df-inverse-text-secondary);
  }
  .df-tier-price {
    font-family: Inter, sans-serif;
    font-size: 44px;
    font-weight: 500;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    margin-bottom: 6px;
  }
  .df-tier-price-note {
    font-size: 13px;
    color: var(--df-text-muted);
    letter-spacing: -0.005em;
    margin-bottom: 36px;
  }
  .df-tier-featured .df-tier-price-note {
    color: var(--df-inverse-text-muted);
  }
  .df-tier-rule {
    height: 1px;
    background: var(--df-hairline);
    margin-bottom: 28px;
  }
  .df-tier-featured .df-tier-rule {
    background: var(--df-hairline-on-dark);
  }
  .df-tier-list {
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .df-tier-list li {
    font-size: 14px;
    color: var(--df-text-secondary);
    letter-spacing: -0.005em;
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
  }
  .df-tier-featured .df-tier-list li {
    color: var(--df-inverse-text-secondary);
  }
  .df-tier-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 8px;
    height: 1px;
    background: var(--df-accent);
  }
  .df-tier-cta {
    margin-top: 32px;
    font-size: 14px;
    font-weight: 600;
    color: var(--df-accent);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    letter-spacing: -0.005em;
    text-decoration: none;
  }

  /* --- footer --- */
  .df-footer {
    padding: 64px 72px;
    border-top: 1px solid var(--df-hairline);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 24px;
  }
  .df-foot-note {
    font-size: 13px;
    color: var(--df-text-muted);
    letter-spacing: -0.005em;
  }
  .df-nav-foot {
    gap: 24px;
  }

  /* --- responsive --- */
  @media (max-width: 1024px) {
    .df-hero,
    .df-section,
    .df-footer,
    .df-header {
      padding-left: 40px;
      padding-right: 40px;
    }
    .df-hero {
      padding-top: 96px;
      padding-bottom: 96px;
    }
    .df-display {
      font-size: 56px;
    }
    .df-quote-grid,
    .df-pricing-grid {
      padding-left: 0;
    }
    .df-section-head {
      grid-template-columns: 80px 1fr;
    }
  }

  @media (max-width: 720px) {
    .df-hero,
    .df-section,
    .df-footer,
    .df-header {
      padding-left: 24px;
      padding-right: 24px;
    }
    .df-display {
      font-size: 40px;
    }
    .df-title {
      font-size: 30px;
    }
    .df-quote-grid,
    .df-pricing-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .df-section-head {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
