---
/**
 * /talk has been merged into /book as the unified intake.
 *
 * Permanent redirect to /book. Both URLs share the same destination so
 * existing inbound links (referrals, marketing, search index) keep working.
 *
 * /api/talk is left alive for one release cycle to absorb in-flight POSTs
 * from any tabs that loaded the old client JS during deploy.
 */
export const prerender = false

return Astro.redirect('/book', 301)
---
