---
/**
 * Legacy `/admin/assessments/[id]` → new meeting URL (issue #468).
 *
 * The assessment detail page was generalized into the entity-scoped meeting
 * page at `/admin/entities/[entityId]/meetings/[meetingId]`. This stub stays
 * in place as a permanent 301 so existing bookmarks resolve. Lookup uses the
 * `meetings` table (which was backfilled from `assessments` preserving IDs
 * in migration 0025), so the assessment_id from an old URL resolves to the
 * matching meeting row.
 *
 * The old completion endpoint at `POST /api/admin/assessments/[id]/complete`
 * is intentionally left functional during the monitoring window — it is
 * the pre-decoupling behavior (completes + drafts quote + transitions stage).
 * New admin UI routes all flow through the meeting page.
 */

import { env } from 'cloudflare:workers'

const session = Astro.locals.session!
const assessmentId = Astro.params.id!

// The meetings table backfill (migration 0025) preserved IDs, so the same
// ID lookup works. If nothing matches (e.g. an unmigrated pre-0010 row),
// fall back to the entities list.
const meeting = await env.DB.prepare(
  'SELECT id, entity_id FROM meetings WHERE id = ? AND org_id = ?'
)
  .bind(assessmentId, session.orgId)
  .first<{ id: string; entity_id: string }>()

if (!meeting) {
  return Astro.redirect('/admin/entities?error=not_found', 301)
}

return Astro.redirect(`/admin/entities/${meeting.entity_id}/meetings/${meeting.id}`, 301)
